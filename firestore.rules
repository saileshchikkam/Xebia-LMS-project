rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading and writing user profiles
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Allow reading and writing user progress
    match /userProgress/{userId} {
      allow read, write: if true;
    }

    // Allow reading and writing custom login credentials
    match /customCredentials/{email} {
      allow read, write: if true;
    }
  }
}
